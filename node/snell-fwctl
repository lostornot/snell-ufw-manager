#!/bin/bash
# snell-fwctl — Restricted firewall control for Snell proxy ports
# Installed at /usr/local/sbin/snell-fwctl on each node VPS
# Run via sudo by the snellmgr user
#
# ALL output is valid JSON for controller parsing.

set -uo pipefail

readonly VERSION="1.0.0"
readonly BACKUP_DIR="/opt/snell-fwctl/backups"
readonly MAX_BACKUPS=20
readonly DEFAULT_SNELL_CONF="/root/snelldocker/snell-conf/snell.conf"

# ─── JSON helpers ────────────────────────────────────────────────────────────

json_ok() {
    # Usage: json_ok '"key": "val", "key2": 123'
    printf '{"ok": true, %s}\n' "$1"
}

json_err() {
    # Escape double quotes and backslashes in the error message
    local msg
    msg=$(printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g')
    printf '{"ok": false, "error": "%s"}\n' "$msg"
    exit 1
}

# ─── Validation helpers ─────────────────────────────────────────────────────

validate_ip() {
    local ip="$1"
    # Match a.b.c.d where each octet is 0-255
    local octet='(25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9][0-9]|[0-9])'
    local re="^${octet}\.${octet}\.${octet}\.${octet}$"
    if [[ ! "$ip" =~ $re ]]; then
        return 1
    fi
    return 0
}

validate_cidr() {
    local cidr="$1"
    if [[ "$cidr" == */* ]]; then
        local ip="${cidr%/*}"
        local mask="${cidr#*/}"
        validate_ip "$ip" || return 1
        if [[ ! "$mask" =~ ^[0-9]+$ ]] || (( mask < 0 || mask > 32 )); then
            return 1
        fi
        return 0
    else
        validate_ip "$cidr"
    fi
}

validate_ip_cidr() {
    local input="$1"
    if [[ "$input" == "any" || "$input" == "anywhere" ]]; then
        return 0
    fi
    if ! validate_cidr "$input"; then
        json_err "invalid ip/cidr: $input"
    fi
}

validate_port() {
    local port="$1"
    if [[ ! "$port" =~ ^[0-9]+$ ]] || (( port < 1 || port > 65535 )); then
        json_err "invalid port: $port (must be 1-65535)"
    fi
}

# ─── Command: list ───────────────────────────────────────────────────────────

cmd_list() {
    local filter_port="${1:-all}"
    if [[ "$filter_port" != "all" ]]; then
        validate_port "$filter_port"
    fi

    local rules_json="["
    local first=true
    local ufw_output

    ufw_output=$(ufw status numbered 2>&1) || json_err "failed to get ufw status: $ufw_output"

    while IFS= read -r line; do
        if [[ "$line" =~ ^\[\ *([0-9]+)\]\ +([^ ]+)\ +(ALLOW|DENY|LIMIT|ALLOW\ IN|ALLOW\ OUT|DENY\ IN|DENY\ OUT)\ +(.+)$ ]]; then
            local num="${BASH_REMATCH[1]}"
            local target="${BASH_REMATCH[2]}"
            local action="${BASH_REMATCH[3]}"
            local ip
            ip=$(echo "${BASH_REMATCH[4]}" | xargs)

            # Strip (v6) case-insensitively
            target=$(echo "$target" | sed 's/ *(v6)//i')
            ip=$(echo "$ip" | sed 's/ *(v6)//i')

            # Split target into port and proto
            local r_port="$target"
            local r_proto="all"
            if [[ "$target" == */* ]]; then
                r_port="${target%/*}"
                r_proto="${target#*/}"
            fi

            # Apply port filter if requested
            if [[ "$filter_port" != "all" ]]; then
                if [[ "$r_port" != "$filter_port" ]]; then
                    continue
                fi
            fi

            if [[ "$first" == true ]]; then
                first=false
            else
                rules_json+=","
            fi
            rules_json+="{\"num\": ${num}, \"ip\": \"${ip}\", \"port\": \"${r_port}\", \"proto\": \"${r_proto}\", \"action\": \"${action}\"}"
        fi
    done <<< "$ufw_output"

    rules_json+="]"
    json_ok "\"port\": \"${filter_port}\", \"rules\": ${rules_json}"
}

# ─── Command: add ────────────────────────────────────────────────────────────

cmd_add() {
    local ip="${1:-}"
    local port="${2:-}"
    local proto="${3:-both}"
    if [[ -z "$ip" || -z "$port" ]]; then
        json_err "usage: snell-fwctl add <ip_cidr> <port> [tcp|udp|both]"
    fi
    validate_ip_cidr "$ip"
    validate_port "$port"

    local from_clause="from $ip"
    if [[ "$ip" == "any" || "$ip" == "anywhere" ]]; then
        from_clause="any"
    fi

    if [[ "$proto" == "tcp" || "$proto" == "both" ]]; then
        if [[ "$from_clause" == "any" ]]; then
            ufw allow "$port"/tcp >/dev/null 2>&1 || json_err "failed to add tcp rule"
        else
            ufw allow from "$ip" to any port "$port" proto tcp >/dev/null 2>&1 \
                || json_err "failed to add tcp rule for $ip on port $port"
        fi
    fi
    if [[ "$proto" == "udp" || "$proto" == "both" ]]; then
        if [[ "$from_clause" == "any" ]]; then
            ufw allow "$port"/udp >/dev/null 2>&1 || json_err "failed to add udp rule"
        else
            ufw allow from "$ip" to any port "$port" proto udp >/dev/null 2>&1 \
                || json_err "failed to add udp rule for $ip on port $port"
        fi
    fi
    ufw reload >/dev/null 2>&1 || json_err "failed to reload ufw"

    json_ok "\"added\": \"${ip}\", \"port\": ${port}, \"proto\": \"${proto}\""
}

# ─── Command: delete ─────────────────────────────────────────────────────────

cmd_delete() {
    local ip="${1:-}"
    local port="${2:-}"
    if [[ -z "$ip" || -z "$port" ]]; then
        json_err "usage: snell-fwctl delete <ip_cidr> <port>"
    fi
    validate_ip_cidr "$ip"
    validate_port "$port"

    local ufw_output
    ufw_output=$(ufw status numbered 2>&1) || json_err "failed to get ufw status: $ufw_output"

    # Collect matching rule numbers
    local -a rule_nums=()
    while IFS= read -r line; do
        if [[ "$line" =~ ^\[\ *([0-9]+)\]\ +${port}/(tcp|udp)\ +ALLOW\ +IN\ +(.+)$ ]]; then
            local rule_ip
            rule_ip=$(echo "${BASH_REMATCH[3]}" | xargs)
            rule_ip=$(echo "$rule_ip" | sed 's/ *(v6)//i')
            if [[ "$rule_ip" == "$ip" ]]; then
                rule_nums+=("${BASH_REMATCH[1]}")
            fi
        fi
    done <<< "$ufw_output"

    local count=${#rule_nums[@]}
    if (( count == 0 )); then
        json_ok "\"deleted\": \"${ip}\", \"port\": ${port}, \"rules_removed\": 0"
        return
    fi

    # Sort descending to avoid index shifting
    IFS=$'\n' sorted=($(printf '%s\n' "${rule_nums[@]}" | sort -rn)); unset IFS

    for num in "${sorted[@]}"; do
        echo y | ufw delete "$num" >/dev/null 2>&1 \
            || json_err "failed to delete rule #${num}"
    done

    ufw reload >/dev/null 2>&1 || json_err "failed to reload ufw"

    json_ok "\"deleted\": \"${ip}\", \"port\": ${port}, \"rules_removed\": ${count}"
}

cmd_delete_num() {
    local num="${1:-}"
    if [[ -z "$num" ]]; then
        json_err "usage: snell-fwctl delete_num <rule_number>"
    fi
    if [[ ! "$num" =~ ^[0-9]+$ ]]; then
        json_err "invalid rule number: $num"
    fi

    echo y | ufw delete "$num" >/dev/null 2>&1 || json_err "failed to delete rule number $num"
    ufw reload >/dev/null 2>&1 || json_err "failed to reload ufw"

    json_ok "\"deleted_num\": ${num}"
}

# ─── Command: candidates ─────────────────────────────────────────────────────

cmd_candidates() {
    local port="${1:-}"
    local hours="${2:-24}"
    if [[ -z "$port" ]]; then
        json_err "usage: snell-fwctl candidates <port> [hours]"
    fi
    validate_port "$port"
    if [[ ! "$hours" =~ ^[0-9]+$ ]] || (( hours < 1 )); then
        json_err "invalid hours: $hours"
    fi

    # Auto-elevate logging level to medium if it is not already set to medium/high/full
    if command -v ufw &>/dev/null; then
        if ufw status | grep -q "Status: active"; then
            local log_status
            log_status=$(LC_ALL=C ufw status verbose | grep -i '^logging:') || log_status=""
            if [[ ! "$log_status" =~ "medium" && ! "$log_status" =~ "high" && ! "$log_status" =~ "full" ]]; then
                ufw logging medium >/dev/null 2>&1 || true
            fi
        fi
    fi

    local cutoff
    cutoff=$(date -d "-${hours} hours" '+%s' 2>/dev/null) || cutoff=$(date -v-"${hours}"H '+%s' 2>/dev/null) || cutoff=0

    local current_year
    current_year=$(date '+%Y')

    # Gather log lines from traditional syslog files, dedicated ufw logs, and journalctl
    get_logs() {
        # 1. Dedicated ufw log
        if [[ -f /var/log/ufw.log ]]; then
            grep -h -E "UFW (BLOCK|ALLOW)" /var/log/ufw.log.1 /var/log/ufw.log 2>/dev/null || grep -E "UFW (BLOCK|ALLOW)" /var/log/ufw.log 2>/dev/null || true
        fi
        # 2. General syslog (where UFW kernel logs often end up)
        if [[ -f /var/log/syslog ]]; then
            grep -h -E "UFW (BLOCK|ALLOW)" /var/log/syslog.1 /var/log/syslog 2>/dev/null || grep -E "UFW (BLOCK|ALLOW)" /var/log/syslog 2>/dev/null || true
        fi
        # 3. Systemd journal (filtered to recent hours)
        if command -v journalctl &>/dev/null; then
            LC_ALL=C journalctl -k --since "${hours} hours ago" --no-pager -o short 2>/dev/null | grep -E "UFW (BLOCK|ALLOW)" || true
        fi
    }

    # Use awk to parse, filter, and aggregate
    local candidates_json
    candidates_json=$(get_logs | awk -v port="$port" -v cutoff="$cutoff" -v year="$current_year" '
    BEGIN {
        # Month name to number mapping
        m["Jan"]=1; m["Feb"]=2; m["Mar"]=3; m["Apr"]=4;
        m["May"]=5; m["Jun"]=6; m["Jul"]=7; m["Aug"]=8;
        m["Sep"]=9; m["Oct"]=10; m["Nov"]=11; m["Dec"]=12;
    }
    /DPT=/ {
        # Extract DPT value
        dpt=""
        for (i=1; i<=NF; i++) {
            if ($i ~ /^DPT=/) {
                split($i, a, "=")
                dpt = a[2]
                break
            }
        }
        if (dpt != port) next

        # Extract SRC value
        src=""
        for (i=1; i<=NF; i++) {
            if ($i ~ /^SRC=/) {
                split($i, a, "=")
                src = a[2]
                break
            }
        }
        if (src == "") next

        # Determine action (BLOCK or ALLOW)
        action = "BLOCK"
        if (index($0, "[UFW ALLOW]") > 0) action = "ALLOW"
        else if (index($0, "[UFW AUDIT]") > 0) action = "ALLOW"

        # Parse timestamp: support ISO 8601 (2026-06-26T18:40:01), Chinese (6月 26 18:40:01), and standard (Jun 26 18:40:01)
        ts = ""
        # Format 1: ISO 8601 e.g. "2026-06-26T18:40:01.123456+08:00"
        if ($1 ~ /^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}/) {
            split($1, parts, "T")
            date_part = parts[1]
            time_part = substr(parts[2], 1, 8)
            ts = date_part "T" time_part
        }
        # Format 2: Space separated ISO e.g. "2026-06-26 18:40:01"
        else if ($1 ~ /^[0-9]{4}-[0-9]{2}-[0-9]{2}$/) {
            ts = $1 "T" $2
        }
        # Format 3: Traditional syslog e.g. "Jun 26 18:40:01" or "6月 26 18:40:01"
        else {
            mon = m[$1]
            if (mon == "") {
                # Strip non-digits to handle Chinese months e.g. "6月" -> "6", or plain "06"
                clean_m = $1
                gsub(/[^0-9]/, "", clean_m)
                if (clean_m ~ /^[0-9]+$/ && clean_m >= 1 && clean_m <= 12) {
                    mon = clean_m
                } else {
                    mon = 1
                }
            }
            
            day = $2
            gsub(/[^0-9]/, "", day)
            day = sprintf("%02d", day)
            
            time_str = $3
            if (time_str !~ /^[0-9]{2}:[0-9]{2}:[0-9]{2}/) {
                # Scan fields for a time format to be safe
                time_str = "00:00:00"
                for (k=1; k<=5; k++) {
                    if ($k ~ /^[0-9]{2}:[0-9]{2}:[0-9]{2}/) {
                        time_str = substr($k, 1, 8)
                        break
                    }
                }
            } else {
                time_str = substr(time_str, 1, 8)
            }
            
            ts = sprintf("%d-%02d-%02dT%s", year, mon, day, time_str)
        }

        # Aggregate
        count[src]++
        last[src] = ts
        if (!(src in act)) act[src] = action
        if (action == "BLOCK") act[src] = "BLOCK"
    }
    END {
        n = 0
        for (ip in count) {
            n++
            ips[n] = ip
            counts[n] = count[ip]
        }
        # Simple selection sort
        for (i=1; i<n; i++) {
            max_idx = i
            for (j=i+1; j<=n; j++) {
                if (counts[j] > counts[max_idx]) max_idx = j
            }
            if (max_idx != i) {
                tmp = ips[i]; ips[i] = ips[max_idx]; ips[max_idx] = tmp
                tmp = counts[i]; counts[i] = counts[max_idx]; counts[max_idx] = tmp
            }
        }
        # Output JSON array
        printf "["
        for (i=1; i<=n; i++) {
            ip = ips[i]
            if (i > 1) printf ","
            printf "{\"ip\": \"%s\", \"action\": \"%s\", \"count\": %d, \"last_seen\": \"%s\"}", ip, act[ip], count[ip], last[ip]
        }
        printf "]"
    }
    ' 2>/dev/null) || candidates_json="[]"

    local tz_offset
    tz_offset=$(date '+%z')
    local tz_name
    tz_name=$(date '+%Z')
    json_ok "\"port\": ${port}, \"hours\": ${hours}, \"tz_offset\": \"${tz_offset}\", \"tz_name\": \"${tz_name}\", \"candidates\": ${candidates_json}"
}

# ─── Command: sync ───────────────────────────────────────────────────────────

cmd_sync() {
    local port="${1:-}"
    local ip_list="${2:-}"
    if [[ -z "$port" ]]; then
        json_err "usage: snell-fwctl sync <port> <comma_separated_ips>"
    fi
    validate_port "$port"

    # Parse desired IP list
    local -a desired_ips=()
    if [[ -n "$ip_list" ]]; then
        IFS=',' read -ra desired_ips <<< "$ip_list"
        # Validate each IP/CIDR
        for ip in "${desired_ips[@]}"; do
            ip=$(echo "$ip" | xargs)  # trim whitespace
            if [[ -z "$ip" ]]; then continue; fi
            validate_ip_cidr "$ip"
        done
    fi

    # Step 1: Backup before sync
    do_backup >/dev/null 2>&1 || true

    # Step 2: Delete ALL existing rules for this port (highest first)
    local ufw_output
    ufw_output=$(ufw status numbered 2>&1) || json_err "failed to get ufw status: $ufw_output"

    local -a existing_nums=()
    while IFS= read -r line; do
        if [[ "$line" =~ ^\[\ *([0-9]+)\]\ +${port}/(tcp|udp)\ +ALLOW\ +IN ]]; then
            existing_nums+=("${BASH_REMATCH[1]}")
        fi
    done <<< "$ufw_output"

    if (( ${#existing_nums[@]} > 0 )); then
        IFS=$'\n' sorted=($(printf '%s\n' "${existing_nums[@]}" | sort -rn)); unset IFS
        for num in "${sorted[@]}"; do
            echo y | ufw delete "$num" >/dev/null 2>&1 || true
        done
    fi

    # Step 3: Add each desired IP (tcp + udp)
    local rules_added=0
    local synced_json="["
    local first=true

    for ip in "${desired_ips[@]}"; do
        ip=$(echo "$ip" | xargs)
        if [[ -z "$ip" ]]; then continue; fi

        ufw allow from "$ip" to any port "$port" proto tcp >/dev/null 2>&1 \
            || json_err "failed to add tcp rule for $ip"
        ufw allow from "$ip" to any port "$port" proto udp >/dev/null 2>&1 \
            || json_err "failed to add udp rule for $ip"
        (( rules_added += 2 ))

        if [[ "$first" == true ]]; then
            first=false
        else
            synced_json+=","
        fi
        synced_json+="\"${ip}\""
    done
    synced_json+="]"

    # Step 4: Reload
    ufw reload >/dev/null 2>&1 || json_err "failed to reload ufw"

    json_ok "\"port\": ${port}, \"synced\": ${synced_json}, \"rules_added\": ${rules_added}"
}

# ─── Backup internal helper ──────────────────────────────────────────────────

do_backup() {
    local ts
    ts=$(date '+%Y%m%d-%H%M%S')
    local backup_path="${BACKUP_DIR}/${ts}"

    mkdir -p "$backup_path" || json_err "failed to create backup directory"

    if [[ -f /etc/ufw/user.rules ]]; then
        cp /etc/ufw/user.rules "${backup_path}/user.rules" \
            || json_err "failed to backup user.rules"
    fi
    if [[ -f /etc/ufw/user6.rules ]]; then
        cp /etc/ufw/user6.rules "${backup_path}/user6.rules" \
            || json_err "failed to backup user6.rules"
    fi

    # Prune old backups (keep only MAX_BACKUPS most recent)
    local -a all_backups
    mapfile -t all_backups < <(ls -1d "${BACKUP_DIR}"/[0-9]* 2>/dev/null | sort)
    local total=${#all_backups[@]}
    if (( total > MAX_BACKUPS )); then
        local to_remove=$(( total - MAX_BACKUPS ))
        for (( i=0; i<to_remove; i++ )); do
            rm -rf "${all_backups[$i]}"
        done
    fi

    echo "${ts}|${backup_path}"
}

# ─── Command: backup ─────────────────────────────────────────────────────────

cmd_backup() {
    local result
    result=$(do_backup) || exit 1

    local ts="${result%%|*}"
    local path="${result##*|}"

    json_ok "\"backup\": \"${ts}\", \"path\": \"${path}\""
}

# ─── Command: restore ────────────────────────────────────────────────────────

cmd_restore() {
    local ts="${1:-}"
    if [[ -z "$ts" ]]; then
        json_err "usage: snell-fwctl restore <timestamp>"
    fi

    # Sanitize: only allow expected timestamp format
    if [[ ! "$ts" =~ ^[0-9]{8}-[0-9]{6}$ ]]; then
        json_err "invalid timestamp format: $ts (expected YYYYMMDD-HHMMSS)"
    fi

    local backup_path="${BACKUP_DIR}/${ts}"
    if [[ ! -d "$backup_path" ]]; then
        json_err "backup not found: $ts"
    fi

    if [[ -f "${backup_path}/user.rules" ]]; then
        cp "${backup_path}/user.rules" /etc/ufw/user.rules \
            || json_err "failed to restore user.rules"
    fi
    if [[ -f "${backup_path}/user6.rules" ]]; then
        cp "${backup_path}/user6.rules" /etc/ufw/user6.rules \
            || json_err "failed to restore user6.rules"
    fi

    ufw reload >/dev/null 2>&1 || json_err "failed to reload ufw after restore"

    json_ok "\"restored\": \"${ts}\""
}

# ─── Command: backups ────────────────────────────────────────────────────────

cmd_backups() {
    local backups_json="["
    local first=true

    if [[ -d "$BACKUP_DIR" ]]; then
        while IFS= read -r dir; do
            [[ -z "$dir" ]] && continue
            local name
            name=$(basename "$dir")
            # Parse date from dirname: YYYYMMDD-HHMMSS → YYYY-MM-DD HH:MM:SS
            local formatted_date=""
            if [[ "$name" =~ ^([0-9]{4})([0-9]{2})([0-9]{2})-([0-9]{2})([0-9]{2})([0-9]{2})$ ]]; then
                formatted_date="${BASH_REMATCH[1]}-${BASH_REMATCH[2]}-${BASH_REMATCH[3]} ${BASH_REMATCH[4]}:${BASH_REMATCH[5]}:${BASH_REMATCH[6]}"
            fi
            # Calculate total size in bytes
            local size
            size=$(du -sb "$dir" 2>/dev/null | cut -f1) || size=0

            if [[ "$first" == true ]]; then
                first=false
            else
                backups_json+=","
            fi
            backups_json+="{\"name\": \"${name}\", \"date\": \"${formatted_date}\", \"size\": ${size}}"
        done < <(ls -1d "${BACKUP_DIR}"/[0-9]* 2>/dev/null | sort)
    fi

    backups_json+="]"
    json_ok "\"backups\": ${backups_json}"
}

# ─── Command: port ───────────────────────────────────────────────────────────

cmd_port() {
    local conf="${1:-${DEFAULT_SNELL_CONF}}"

    if [[ ! -f "$conf" ]]; then
        json_err "config file not found: $conf"
    fi

    local port=""
    while IFS= read -r line; do
        # Match: listen = 0.0.0.0:28261  or  listen = ::0:28261
        if [[ "$line" =~ ^[[:space:]]*listen[[:space:]]*=[[:space:]]*.*:([0-9]+)[[:space:]]*$ ]]; then
            port="${BASH_REMATCH[1]}"
            break
        fi
    done < "$conf"

    if [[ -z "$port" ]]; then
        json_err "could not parse port from $conf"
    fi

    json_ok "\"port\": ${port}, \"conf\": \"${conf}\""
}

# ─── Command: status ─────────────────────────────────────────────────────────

cmd_status() {
    local ufw_status
    ufw_status=$(ufw status 2>&1 | head -1 | awk '{print $2}') || ufw_status="unknown"
    # Lowercase
    ufw_status=$(echo "$ufw_status" | tr '[:upper:]' '[:lower:]')

    local hostname_val
    hostname_val=$(hostname 2>/dev/null) || hostname_val="unknown"

    local uptime_val
    uptime_val=$(uptime -p 2>/dev/null | sed 's/^up //' || uptime 2>/dev/null | sed 's/.*up *//' | sed 's/,.*//')
    uptime_val=${uptime_val:-"unknown"}

    local kernel_val
    kernel_val=$(uname -r 2>/dev/null) || kernel_val="unknown"

    json_ok "\"ufw_status\": \"${ufw_status}\", \"hostname\": \"${hostname_val}\", \"uptime\": \"${uptime_val}\", \"kernel\": \"${kernel_val}\", \"fwctl_version\": \"${VERSION}\""
}

# ─── Main dispatch ───────────────────────────────────────────────────────────

main() {
    local cmd="${1:-}"
    shift 2>/dev/null || true

    case "$cmd" in
        list)       cmd_list "$@" ;;
        add)        cmd_add "$@" ;;
        delete)     cmd_delete "$@" ;;
        delete_num) cmd_delete_num "$@" ;;
        candidates) cmd_candidates "$@" ;;
        sync)       cmd_sync "$@" ;;
        backup)     cmd_backup "$@" ;;
        restore)    cmd_restore "$@" ;;
        backups)    cmd_backups "$@" ;;
        port)       cmd_port "$@" ;;
        status)     cmd_status "$@" ;;
        "")         json_err "usage: snell-fwctl <command> [args...]\ncommands: list, add, delete, delete_num, candidates, sync, backup, restore, backups, port, status" ;;
        *)          json_err "unknown command: $cmd" ;;
    esac
}

main "$@"
